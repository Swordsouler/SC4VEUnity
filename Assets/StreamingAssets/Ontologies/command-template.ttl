@prefix : <https://sc4ve.lisn.upsaclay.fr/ontology#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sven: <https://sven.lisn.upsaclay.fr/ontology#> .
@prefix sc4ve: <https://sc4ve.lisn.upsaclay.fr/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://sc4ve.lisn.upsaclay.fr/ontology#> .

<https://sc4ve.lisn.upsaclay.fr/ontology> rdf:type owl:Ontology ;
                                           dcterms:license <https://opensource.org/licenses/MIT> ;
                                           rdfs:comment "Ontologie SC4VE (Semantic Command for Virtual Environment) : modélisation simplifiée des Commandes avec paramètres requis et optionnels, sans notion de binding ni d'index." .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://sc4ve.lisn.upsaclay.fr/ontology#hasOptionalParameter
sc4ve:hasOptionalParameter rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf sc4ve:hasParameter .


###  https://sc4ve.lisn.upsaclay.fr/ontology#hasParameter
sc4ve:hasParameter rdf:type owl:ObjectProperty ;
                   rdfs:domain sc4ve:Command ;
                   rdfs:range sc4ve:Parameter .


###  https://sc4ve.lisn.upsaclay.fr/ontology#hasRequiredParameter
sc4ve:hasRequiredParameter rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf sc4ve:hasParameter .


#################################################################
#    Classes
#################################################################

###  https://sc4ve.lisn.upsaclay.fr/ontology#ColorParameter
sc4ve:ColorParameter rdf:type owl:Class ;
                     rdfs:subClassOf sc4ve:Parameter , sven:Color .


###  https://sc4ve.lisn.upsaclay.fr/ontology#ColorizeCommand
sc4ve:ColorizeCommand rdf:type owl:Class ;
                      rdfs:subClassOf sc4ve:Command ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty sc4ve:hasParameter ;
                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                        owl:onClass sc4ve:ColorParameter
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty sc4ve:hasParameter ;
                                        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                        owl:onClass sc4ve:SelectionParameter
                                      ] .


###  https://sc4ve.lisn.upsaclay.fr/ontology#Command
sc4ve:Command rdf:type owl:Class .


###  https://sc4ve.lisn.upsaclay.fr/ontology#MoveToPointWithColor
sc4ve:MoveToPointWithColor rdf:type owl:Class ;
                           rdfs:subClassOf sc4ve:Command ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty sc4ve:hasParameter ;
                                             owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                             owl:onClass sc4ve:PointParameter
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty sc4ve:hasParameter ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass sc4ve:ColorParameter
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty sc4ve:hasParameter ;
                                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass sc4ve:SelectionParameter
                                           ] .


###  https://sc4ve.lisn.upsaclay.fr/ontology#Parameter
sc4ve:Parameter rdf:type owl:Class .


###  https://sc4ve.lisn.upsaclay.fr/ontology#PointParameter
sc4ve:PointParameter rdf:type owl:Class ;
                     rdfs:subClassOf sc4ve:Parameter , sven:Vector2 .


###  https://sc4ve.lisn.upsaclay.fr/ontology#SelectionParameter
sc4ve:SelectionParameter rdf:type owl:Class ;
                         rdfs:subClassOf sc4ve:Parameter , sven:Primitive .


#################################################################
#    Individuals
#################################################################

###  https://sc4ve.lisn.upsaclay.fr/ontology#MoveToPointWithColorCommandInstance
sc4ve:MoveToPointWithColorCommandInstance rdf:type owl:NamedIndividual ,
                                                   sc4ve:MoveToPointWithColor ;
                                          sc4ve:hasParameter sc4ve:param_color ,
                                                             sc4ve:param_pointA ,
                                                             sc4ve:param_pointB .


###  https://sc4ve.lisn.upsaclay.fr/ontology#param_color
sc4ve:param_color rdf:type owl:NamedIndividual ,
                           sc4ve:ColorParameter .


###  https://sc4ve.lisn.upsaclay.fr/ontology#param_pointA
sc4ve:param_pointA rdf:type owl:NamedIndividual ,
                            sc4ve:PointParameter .


###  https://sc4ve.lisn.upsaclay.fr/ontology#param_pointB
sc4ve:param_pointB rdf:type owl:NamedIndividual ,
                            sc4ve:PointParameter .


