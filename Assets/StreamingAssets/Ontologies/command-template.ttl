@prefix : <https://sc4ve.lisn.upsaclay.fr/ontology#> .
@prefix sc4ve: <https://sc4ve.lisn.upsaclay.fr/ontology#> .
@prefix sven: <https://sven.lisn.upsaclay.fr/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@base <https://sc4ve.lisn.upsaclay.fr/ontology> .

<https://sc4ve.lisn.upsaclay.fr/ontology> rdf:type owl:Ontology ;
    dcterms:license <https://opensource.org/licenses/MIT> ;
    rdfs:comment "Ontologie SC4VE (Semantic Command for Virtual Environment) : modélisation des Commandes avec paramètres ordonnés et requis/optionnels, compatible Protégé." .

#################################################################
# CLASSES
#################################################################

sc4ve:Command rdf:type owl:Class .
sc4ve:Parameter rdf:type owl:Class .
sc4ve:ParameterBinding rdf:type owl:Class .

sc4ve:PointParameter rdf:type owl:Class ; rdfs:subClassOf sc4ve:Parameter .
sc4ve:ColorParameter rdf:type owl:Class ; rdfs:subClassOf sc4ve:Parameter .
sc4ve:SelectionParameter rdf:type owl:Class ; rdfs:subClassOf sc4ve:Parameter .

#################################################################
# PROPRIÉTÉS
#################################################################

sc4ve:hasParameterBinding rdf:type owl:ObjectProperty ;
    rdfs:domain sc4ve:Command ;
    rdfs:range sc4ve:ParameterBinding .

sc4ve:boundParameter rdf:type owl:ObjectProperty ;
    rdfs:domain sc4ve:ParameterBinding ;
    rdfs:range sc4ve:Parameter .

sc4ve:parameterIndex rdf:type owl:DatatypeProperty ;
    rdfs:domain sc4ve:ParameterBinding ;
    rdfs:range xsd:integer .

sc4ve:isRequired rdf:type owl:DatatypeProperty ;
    rdfs:domain sc4ve:ParameterBinding ;
    rdfs:range xsd:boolean .

#################################################################
# COMMANDE MoveToPointWithColor
#################################################################

sc4ve:ColorizeCommand rdf:type owl:Class ;
    rdfs:subClassOf sc4ve:Command ,
        # 1 couleur requise
        [ rdf:type owl:Restriction ;
          owl:onProperty sc4ve:hasParameterBinding ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass [ rdf:type owl:Class ;
              owl:intersectionOf (
                  sc4ve:ParameterBinding
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:boundParameter ;
                    owl:allValuesFrom sc4ve:ColorParameter ]
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:isRequired ;
                    owl:hasValue true ]
              )
          ]
        ] ,
        # 1 sélection optionnelle
        [ rdf:type owl:Restriction ;
          owl:onProperty sc4ve:hasParameterBinding ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass [ rdf:type owl:Class ;
              owl:intersectionOf (
                  sc4ve:ParameterBinding
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:boundParameter ;
                    owl:allValuesFrom sc4ve:SelectionParameter ]
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:isRequired ;
                    owl:hasValue false ]
              )
          ]
        ] .

sc4ve:MoveToPointWithColor rdf:type owl:Class ;
    rdfs:subClassOf sc4ve:Command ,
        # 2 points requis
        [ rdf:type owl:Restriction ;
          owl:onProperty sc4ve:hasParameterBinding ;
          owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
          owl:onClass [ rdf:type owl:Class ;
              owl:intersectionOf ( 
                  sc4ve:ParameterBinding
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:boundParameter ;
                    owl:allValuesFrom sc4ve:PointParameter ]
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:isRequired ;
                    owl:hasValue true ]
              )
          ]
        ] ,
        # 1 couleur requise
        [ rdf:type owl:Restriction ;
          owl:onProperty sc4ve:hasParameterBinding ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass [ rdf:type owl:Class ;
              owl:intersectionOf (
                  sc4ve:ParameterBinding
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:boundParameter ;
                    owl:allValuesFrom sc4ve:ColorParameter ]
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:isRequired ;
                    owl:hasValue true ]
              )
          ]
        ] ,
        # 1 sélection optionnelle
        [ rdf:type owl:Restriction ;
          owl:onProperty sc4ve:hasParameterBinding ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass [ rdf:type owl:Class ;
              owl:intersectionOf (
                  sc4ve:ParameterBinding
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:boundParameter ;
                    owl:allValuesFrom sc4ve:SelectionParameter ]
                  [ rdf:type owl:Restriction ;
                    owl:onProperty sc4ve:isRequired ;
                    owl:hasValue false ]
              )
          ]
        ] .

#################################################################
# INSTANCES D’ORDRE (compatibles Protégé)
#################################################################

# On crée les bindings explicitement
sc4ve:binding_sel a sc4ve:ParameterBinding ;
    sc4ve:parameterIndex 1 ;
    sc4ve:isRequired false ;
    sc4ve:boundParameter sc4ve:SelectionParameter .

sc4ve:binding_pointA a sc4ve:ParameterBinding ;
    sc4ve:parameterIndex 2 ;
    sc4ve:isRequired true ;
    sc4ve:boundParameter sc4ve:PointParameter .

sc4ve:binding_pointB a sc4ve:ParameterBinding ;
    sc4ve:parameterIndex 3 ;
    sc4ve:isRequired true ;
    sc4ve:boundParameter sc4ve:PointParameter .

sc4ve:binding_color a sc4ve:ParameterBinding ;
    sc4ve:parameterIndex 4 ;
    sc4ve:isRequired true ;
    sc4ve:boundParameter sc4ve:ColorParameter .

sc4ve:MoveToPointWithColorCommandInstance a sc4ve:MoveToPointWithColor ;
    sc4ve:hasParameterBinding sc4ve:binding_sel , sc4ve:binding_pointA , sc4ve:binding_pointB , sc4ve:binding_color .

