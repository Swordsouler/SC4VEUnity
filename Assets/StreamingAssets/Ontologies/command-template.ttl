@prefix : <https://s4m.lisn.upsaclay.fr/ontology#> .
@prefix ve: <https://sven.lisn.upsaclay.fr/ve/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix s4m: <https://s4m.lisn.upsaclay.fr/ontology#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix geof: <http://www.opengis.net/def/function/geosparql/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sven: <https://sven.lisn.upsaclay.fr/ontology#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://s4m.lisn.upsaclay.fr/ontology> .

<https://s4m.lisn.upsaclay.fr/ontology> rdf:type owl:Ontology ;
                                         dcterms:license <https://opensource.org/licenses/MIT> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://s4m.lisn.upsaclay.fr/ontology#boundParameter
s4m:boundParameter rdf:type owl:ObjectProperty ;
                   rdfs:domain s4m:ParameterBinding ;
                   rdfs:range s4m:Parameter .


###  https://s4m.lisn.upsaclay.fr/ontology#parameter
s4m:parameter rdf:type owl:ObjectProperty ;
              rdfs:domain s4m:Command ;
              rdfs:range s4m:Parameter .


###  https://s4m.lisn.upsaclay.fr/ontology#parameterIndex
s4m:parameterIndex rdf:type owl:ObjectProperty ;
                   rdfs:domain s4m:Command ,
                               s4m:ParameterBinding ;
                   rdfs:range s4m:ParameterBinding .


#################################################################
#    Data properties
#################################################################

###  https://s4m.lisn.upsaclay.fr/ontology#parameterIndex
s4m:parameterIndex rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:integer .


#################################################################
#    Classes
#################################################################

###  https://s4m.lisn.upsaclay.fr/ontology#ColorParameter
s4m:ColorParameter rdf:type owl:Class ;
                   rdfs:subClassOf s4m:Parameter .


###  https://s4m.lisn.upsaclay.fr/ontology#ColorizeCommand
s4m:ColorizeCommand rdf:type owl:Class ;
                    rdfs:subClassOf s4m:Command .


###  https://s4m.lisn.upsaclay.fr/ontology#Command
s4m:Command rdf:type owl:Class .


###  https://s4m.lisn.upsaclay.fr/ontology#Parameter
s4m:Parameter rdf:type owl:Class .


###  https://s4m.lisn.upsaclay.fr/ontology#ParameterBinding
s4m:ParameterBinding rdf:type owl:Class .


###  https://s4m.lisn.upsaclay.fr/ontology#SelectCommand
s4m:SelectCommand rdf:type owl:Class ;
                  rdfs:subClassOf s4m:Command .


###  https://s4m.lisn.upsaclay.fr/ontology#SelectionParameter
s4m:SelectionParameter rdf:type owl:Class ;
                       rdfs:subClassOf s4m:Parameter .


###  Generated by the OWL API (version 4.5.26.2023-07-17T20:34:13Z) https://github.com/owlcs/owlapi
# Sous-classes pour distinguer requis / optionnel
s4m:RequiredParameterBinding rdf:type owl:Class ;
    rdfs:subClassOf s4m:ParameterBinding .

s4m:OptionalParameterBinding rdf:type owl:Class ;
    rdfs:subClassOf s4m:ParameterBinding .

s4m:ColorBinding rdf:type owl:Class ;
    rdfs:subClassOf s4m:RequiredParameterBinding ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty s4m:boundParameter ;
        owl:allValuesFrom s4m:ColorParameter
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty s4m:parameterIndex ;
        owl:hasValue "1"^^xsd:integer
    ] .