@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix geof: <http://www.opengis.net/def/function/geosparql/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sven: <https://sven.lisn.upsaclay.fr/ontology#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix sc4ve: <https://sc4ve.lisn.upsaclay.fr/ontology#> .
@prefix ve: <https://sven.lisn.upsaclay.fr/ve/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@base <https://sc4ve.lisn.upsaclay.fr/ontology#> .

<https://sc4ve.lisn.upsaclay.fr/ontology> rdf:type owl:Ontology ;
                                           dcterms:license <https://opensource.org/licenses/MIT> ;
                                           rdfs:comment "Ontologie SC4VE (Semantic Command for Virtual Environment) : modélisation simplifiée des Commandes avec paramètres requis et optionnels, sans notion de binding ni d'index."@fr ,
                                                        "SC4VE (Semantic Command for Virtual Environment) ontology: simplified modeling of Commands with required and optional parameters, without binding or index notion."@en ;
                                           rdfs:label "Ontologie SC4VE"@fr ,
                                                      "SC4VE Ontology"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://sc4ve.lisn.upsaclay.fr/ontology#hasParameter
sc4ve:hasParameter rdf:type owl:ObjectProperty ;
                   rdfs:domain sc4ve:Command ;
                   rdfs:range sc4ve:Parameter ;
                   rdfs:comment "Relates a Command to one of its Parameters."@en ,
                                "Relie une Commande à l'un de ses Paramètres."@fr ;
                   rdfs:label "a pour paramètre"@fr ,
                              "has parameter"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#hasWord
sc4ve:hasWord rdf:type owl:ObjectProperty ;
              rdfs:domain sc4ve:Sentence ;
              rdfs:range sc4ve:Word ;
              rdfs:comment "Relates a Sentence to one of its Words."@en ,
                           "Relie une Phrase à l'un de ses Mots."@fr ;
              rdfs:label "a pour mot"@fr ,
                         "has word"@en .


#################################################################
#    Data properties
#################################################################

###  https://sc4ve.lisn.upsaclay.fr/ontology#confidence
sc4ve:confidence rdf:type owl:DatatypeProperty ;
                 rdfs:domain sc4ve:Sentence ;
                 rdfs:range xsd:float ;
                 rdfs:comment "Le score de confiance de la phrase reconnue."@fr ,
                              "The confidence score of the recognized sentence."@en ;
                 rdfs:label "confiance"@fr ,
                            "confidence"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#text
sc4ve:text rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:string ;
           rdfs:comment "Le texte du mot reconnu."@fr ,
                        "The text of the recognized word."@en ;
           rdfs:label "text"@en ,
                      "texte"@fr .


#################################################################
#    Classes
#################################################################

###  https://sc4ve.lisn.upsaclay.fr/ontology#Color
sc4ve:Color rdf:type owl:Class .


###  https://sc4ve.lisn.upsaclay.fr/ontology#ColorParameter
sc4ve:ColorParameter rdf:type owl:Class ;
                     rdfs:subClassOf sc4ve:Parameter ,
                                     sven:Color ;
                     rdfs:comment "A parameter representing a color."@en ,
                                  "Un paramètre représentant une couleur."@fr ;
                     rdfs:label "Color Parameter"@en ,
                                "Paramètre de Couleur"@fr .


###  https://sc4ve.lisn.upsaclay.fr/ontology#ColorizeCommand
sc4ve:ColorizeCommand rdf:type owl:Class ;
                      rdfs:subClassOf sc4ve:Command ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty sc4ve:hasParameter ;
                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                        owl:onClass sc4ve:ColorParameter
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty sc4ve:hasParameter ;
                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                        owl:onClass sc4ve:SelectionParameter
                                      ] ;
                      rdfs:comment "A command to colorize selected objects with a specified color."@en ,
                                   "Une commande pour colorer des objets sélectionnés avec une couleur spécifiée."@fr ;
                      rdfs:label "Colorize Command"@en ,
                                 "Commande de Coloration"@fr .


###  https://sc4ve.lisn.upsaclay.fr/ontology#Command
sc4ve:Command rdf:type owl:Class ;
              rdfs:comment "An abstract class representing a command that can be executed in the virtual environment."@en ,
                           "Une classe abstraite représentant une commande pouvant être exécutée dans l'environnement virtuel."@fr ;
              rdfs:label "Command"@en ,
                         "Commande"@fr .


###  https://sc4ve.lisn.upsaclay.fr/ontology#GrabCommand
sc4ve:GrabCommand rdf:type owl:Class ;
                  rdfs:subClassOf sc4ve:Command ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty sc4ve:hasParameter ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass sc4ve:SelectionParameter
                                  ] ;
                  rdfs:comment "A command to grab selected objects."@en ,
                               "Une commande pour saisir des objets sélectionnés."@fr ;
                  rdfs:label "Commande de Saisie"@fr ,
                             "Grab Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#HideCommand
sc4ve:HideCommand rdf:type owl:Class ;
                  rdfs:subClassOf sc4ve:Command ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty sc4ve:hasParameter ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass sc4ve:SelectionParameter
                                  ] ;
                  rdfs:comment "A command to hide selected objects."@en ,
                               "Une commande pour masquer des objets sélectionnés."@fr ;
                  rdfs:label "Commande de Masquage"@fr ,
                             "Hide Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#MeasureCommand
sc4ve:MeasureCommand rdf:type owl:Class ;
                     rdfs:subClassOf sc4ve:Command ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty sc4ve:hasParameter ;
                                       owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                       owl:onClass sc4ve:PointParameter
                                     ] ;
                     rdfs:comment "A command to measure the distance between two points."@en ,
                                  "Une commande pour mesurer la distance entre deux points."@fr ;
                     rdfs:label "Commande de Mesure"@fr ,
                                "Measure Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#MoveCommand
sc4ve:MoveCommand rdf:type owl:Class ;
                  rdfs:subClassOf sc4ve:Command ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty sc4ve:hasParameter ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass sc4ve:PointParameter
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty sc4ve:hasParameter ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass sc4ve:SelectionParameter
                                  ] ;
                  rdfs:comment "A command to move selected objects to a specified point."@en ,
                               "Une commande pour déplacer des objets sélectionnés vers un point spécifié."@fr ;
                  rdfs:label "Commande de Déplacement"@fr ,
                             "Move Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#Parameter
sc4ve:Parameter rdf:type owl:Class ;
                rdfs:comment "An abstract class representing a parameter for a command."@en ,
                             "Une classe abstraite représentant un paramètre pour une commande."@fr ;
                rdfs:label "Parameter"@en ,
                           "Paramètre"@fr .


###  https://sc4ve.lisn.upsaclay.fr/ontology#PointParameter
sc4ve:PointParameter rdf:type owl:Class ;
                     rdfs:subClassOf sc4ve:Parameter ,
                                     sven:Vector2 ;
                     rdfs:comment "A parameter representing a point in 2D space."@en ,
                                  "Un paramètre représentant un point dans l'espace 2D."@fr ;
                     rdfs:label "Paramètre de Point"@fr ,
                                "Point Parameter"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#ReleaseCommand
sc4ve:ReleaseCommand rdf:type owl:Class ;
                     rdfs:subClassOf sc4ve:Command ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty sc4ve:hasParameter ;
                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass sc4ve:SelectionParameter
                                     ] ;
                     rdfs:comment "A command to release grabbed objects."@en ,
                                  "Une commande pour relâcher des objets saisis."@fr ;
                     rdfs:label "Commande de Relâchement"@fr ,
                                "Release Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#ScaleDownCommand
sc4ve:ScaleDownCommand rdf:type owl:Class ;
                       rdfs:subClassOf sc4ve:Command ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty sc4ve:hasParameter ;
                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass sc4ve:SelectionParameter
                                       ] ;
                       rdfs:comment "A command to scale down selected objects."@en ,
                                    "Une commande pour réduire la taille des objets sélectionnés."@fr ;
                       rdfs:label "Commande de Réduction de taille"@fr ,
                                  "Scale Down Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#ScaleUpCommand
sc4ve:ScaleUpCommand rdf:type owl:Class ;
                     rdfs:subClassOf sc4ve:Command ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty sc4ve:hasParameter ;
                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass sc4ve:SelectionParameter
                                     ] ;
                     rdfs:comment "A command to scale up selected objects."@en ,
                                  "Une commande pour agrandir la taille des objets sélectionnés."@fr ;
                     rdfs:label "Commande d'Agrandissement de taille"@fr ,
                                "Scale Up Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#SelectCommand
sc4ve:SelectCommand rdf:type owl:Class ;
                    rdfs:subClassOf sc4ve:Command ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty sc4ve:hasParameter ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass sc4ve:SelectionParameter
                                    ] ;
                    rdfs:comment "A command to select objects."@en ,
                                 "Une commande pour sélectionner des objets."@fr ;
                    rdfs:label "Commande de Sélection"@fr ,
                               "Select Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#SelectionParameter
sc4ve:SelectionParameter rdf:type owl:Class ;
                         rdfs:subClassOf sc4ve:Parameter ,
                                         sven:Primitive ;
                         rdfs:comment "A parameter representing a selection of objects."@en ,
                                      "Un paramètre représentant une sélection d'objets."@fr ;
                         rdfs:label "Paramètre de Sélection"@fr ,
                                    "Selection Parameter"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#Sentence
sc4ve:Sentence rdf:type owl:Class ;
               rdfs:subClassOf sven:Event ;
               rdfs:comment "A sentence said by the user"@en ,
                            "Une phrase prononcée par l'utilisateur"@fr ;
               rdfs:label "Phrase"@fr ,
                          "Sentence"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#ShowCommand
sc4ve:ShowCommand rdf:type owl:Class ;
                  rdfs:subClassOf sc4ve:Command ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty sc4ve:hasParameter ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass sc4ve:SelectionParameter
                                  ] ;
                  rdfs:comment "A command to show selected objects."@en ,
                               "Une commande pour afficher des objets sélectionnés."@fr ;
                  rdfs:label "Commande d'Affichage"@fr ,
                             "Show Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#UnselectCommand
sc4ve:UnselectCommand rdf:type owl:Class ;
                      rdfs:subClassOf sc4ve:Command ;
                      rdfs:comment "A command to unselect objects (optionally all of them)."@en ,
                                   "Une commande pour désélectionner des objets (éventuellement tous)."@fr ;
                      rdfs:label "Commande de Désélection"@fr ,
                                 "Unselect Command"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#Word
sc4ve:Word rdf:type owl:Class ;
           rdfs:subClassOf sven:Event ;
           rdfs:comment "A word said by the user"@en ,
                        "Un mot prononcé par l'utilisateur"@fr ;
           rdfs:label "Mot"@fr ,
                      "Word"@en .


###  https://sven.lisn.upsaclay.fr/ontology#Color
sven:Color rdf:type owl:Class .


###  https://sven.lisn.upsaclay.fr/ontology#Event
sven:Event rdf:type owl:Class .


###  https://sven.lisn.upsaclay.fr/ontology#Primitive
sven:Primitive rdf:type owl:Class .


###  https://sven.lisn.upsaclay.fr/ontology#Vector2
sven:Vector2 rdf:type owl:Class .


#################################################################
#    Gestion d'ambiguïté — messages bilingues
#################################################################

###  https://sc4ve.lisn.upsaclay.fr/ontology#clarification
sc4ve:clarification rdf:type owl:DatatypeProperty ;
                    rdfs:domain sc4ve:Parameter ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Question posée à l'utilisateur lorsqu'un paramètre requis de ce type est manquant."@fr ,
                                 "Question asked to the user when a required parameter of this type is missing."@en ;
                    rdfs:label "clarification"@en ,
                               "clarification"@fr .


###  Messages de clarification par type de paramètre manquant (manque de paramètre)
sc4ve:SelectionParameter sc4ve:clarification "Sur quels objets ?"@fr ,
                                             "On which objects?"@en .

sc4ve:ColorParameter sc4ve:clarification "En quelle couleur ?"@fr ,
                                         "In which color?"@en .

sc4ve:PointParameter sc4ve:clarification "À quel endroit ?"@fr ,
                                         "To which location?"@en .


###  https://sc4ve.lisn.upsaclay.fr/ontology#notUnderstood
###  Message générique énoncé quand aucune intention n'est reconnue (manque de sens).
sc4ve:notUnderstood rdf:type owl:NamedIndividual ;
                    rdfs:comment "Énoncé quand aucune intention n'est reconnue."@fr ,
                                 "Spoken when no intent is recognized."@en ;
                    rdfs:label "Je n'ai pas compris, peux-tu reformuler ?"@fr ,
                               "I didn't understand, could you rephrase?"@en .


#################################################################
#    Commandes — exigences de paramètres (lues par ClarificationVocabulary)
#
#    AJOUTER UNE COMMANDE (voir COMMANDS.md, Étape 4) :
#    1. Déclarer une classe sous sc4ve:Command, avec labels @fr ET @en.
#       Le nom local DOIT être identique au type C# (ex: sc4ve:RotateLeftCommand
#       <-> RotateLeftCommand).
#    2. Pour chaque paramètre REQUIS, ajouter une restriction OWL :
#         [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ;
#           owl:qualifiedCardinality "N"^^xsd:nonNegativeInteger ;
#           owl:onClass sc4ve:XParameter ]
#       - paramètre optionnel -> PAS de restriction (sinon clarification a tort)
#       - aucun paramètre requis -> aucune restriction
#    3. Nouveau type de paramètre -> ajouter sa classe + sc4ve:clarification (@fr/@en).
#################################################################

###  Commandes agissant sur une sélection (1 SelectionParameter requis)
sc4ve:AlignCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Align Command"@en , "Commande d'Alignement"@fr .

sc4ve:ColorizeDarkerCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Darken Command"@en , "Commande d'Assombrissement"@fr .

sc4ve:ColorizeLighterCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Lighten Command"@en , "Commande d'Éclaircissement"@fr .

sc4ve:CountCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Count Command"@en , "Commande de Comptage"@fr .

sc4ve:DeleteCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Delete Command"@en , "Commande de Suppression"@fr .

sc4ve:DescribeCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Describe Command"@en , "Commande de Description"@fr .

sc4ve:DuplicateCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Duplicate Command"@en , "Commande de Duplication"@fr .

sc4ve:FlipCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Flip Command"@en , "Commande de Retournement"@fr .

sc4ve:FocusCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Focus Command"@en , "Commande de Focalisation"@fr .

sc4ve:HighlightCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Highlight Command"@en , "Commande de Mise en Évidence"@fr .

sc4ve:ResetColorCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Reset Color Command"@en , "Commande de Réinitialisation de Couleur"@fr .

sc4ve:ResetScaleCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Reset Scale Command"@en , "Commande de Réinitialisation de Taille"@fr .

sc4ve:ResetTransformCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Reset Transform Command"@en , "Commande de Réinitialisation de Transformation"@fr .

sc4ve:RotateLeftCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Rotate Left Command"@en , "Commande de Rotation Gauche"@fr .

sc4ve:RotateRightCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Rotate Right Command"@en , "Commande de Rotation Droite"@fr .

sc4ve:SetOpaqueCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Set Opaque Command"@en , "Commande d'Opacité"@fr .

sc4ve:SetTransparentCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Set Transparent Command"@en , "Commande de Transparence"@fr .

sc4ve:SnapToGroundCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Snap To Ground Command"@en , "Commande de Pose au Sol"@fr .

###  Copie de couleur : 2 SelectionParameter (cible + source)
sc4ve:ColorizeCopyCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ,
    [ rdf:type owl:Restriction ; owl:onProperty sc4ve:hasParameter ; owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass sc4ve:SelectionParameter ] ;
    rdfs:label "Copy Color Command"@en , "Commande de Copie de Couleur"@fr .

###  Commandes sans paramètre requis (aucune restriction → aucune clarification)
sc4ve:InvertSelectionCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ;
    rdfs:label "Invert Selection Command"@en , "Commande d'Inversion de Sélection"@fr .

sc4ve:SelectAllCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ;
    rdfs:label "Select All Command"@en , "Commande de Sélection Totale"@fr .

sc4ve:ResetSceneCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ;
    rdfs:label "Reset Scene Command"@en , "Commande de Réinitialisation de Scène"@fr .

sc4ve:UndoCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ;
    rdfs:label "Undo Command"@en , "Commande d'Annulation"@fr .

sc4ve:RedoCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ;
    rdfs:label "Redo Command"@en , "Commande de Rétablissement"@fr .


