sc4ve:RedoCommand rdf:type owl:Class ; rdfs:subClassOf sc4ve:Command ;
    rdfs:label "Redo Command"@en , "Commande de Rétablissement"@fr .


#################################################################
#    Triggers de commandes (rule-based) — bilingues
#
#    Une valeur sc4ve:trigger par forme ET par langue (@fr / @en). Lu par
#    CommandVocabulary, filtré sur UserData.Locale. Le repli sur l'attribut C#
#    [RuleBasedTriggers] couvre les commandes pas encore migrées ici.
#    Voir COMMANDS.md, Étape 4.
#################################################################

sc4ve:trigger rdf:type owl:DatatypeProperty ;
              rdfs:domain sc4ve:Command ;
              rdfs:range xsd:string ;
              rdfs:comment "Locution déclenchant la commande en mode rule-based (une valeur par forme et par langue)."@fr ,
                           "Phrase triggering the command in rule-based mode (one value per form and language)."@en ;
              rdfs:label "déclencheur"@fr ,
                         "trigger"@en .

