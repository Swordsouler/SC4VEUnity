#################################################################
#    Descriptions LLM bilingues des commandes complémentaires
#    (les 11 commandes d'origine ont déjà leur rdfs:comment plus haut)
#################################################################

sc4ve:AlignCommand rdfs:comment "Aligne les objets à la même hauteur (Y) que le premier sélectionné."@fr , "Aligns objects to the same height (Y) as the first selected one."@en .
sc4ve:ColorizeCopyCommand rdfs:comment "Applique la couleur d'un objet (source) à d'autres (cible)."@fr , "Applies the color of one object (source) to others (target)."@en .
sc4ve:ColorizeDarkerCommand rdfs:comment "Assombrit la couleur des objets."@fr , "Darkens the objects' color."@en .
sc4ve:ColorizeLighterCommand rdfs:comment "Éclaircit la couleur des objets."@fr , "Lightens the objects' color."@en .
sc4ve:CountCommand rdfs:comment "Compte les objets correspondant au filtre et l'énonce."@fr , "Counts the objects matching the filter and announces the result."@en .
sc4ve:DeleteCommand rdfs:comment "Supprime (désactive) les objets sélectionnés ; annulable."@fr , "Deletes (disables) the selected objects; undoable."@en .
sc4ve:DescribeCommand rdfs:comment "Décrit les propriétés des objets (position, couleur…)."@fr , "Describes the objects' properties (position, color…)."@en .
sc4ve:DuplicateCommand rdfs:comment "Duplique les objets ; avec une destination, instancie la copie à cet endroit."@fr , "Duplicates objects; with a destination, instantiates the copy there."@en .
sc4ve:FlipCommand rdfs:comment "Retourne les objets de 180° (axe Y)."@fr , "Flips objects by 180° (Y axis)."@en .
sc4ve:FocusCommand rdfs:comment "Oriente la caméra principale vers les objets."@fr , "Points the main camera toward the objects."@en .
sc4ve:HighlightCommand rdfs:comment "Active ou désactive la mise en évidence des objets."@fr , "Toggles highlighting of the objects."@en .
sc4ve:ResetColorCommand rdfs:comment "Remet les objets à leur couleur d'origine."@fr , "Restores the objects' original color."@en .
sc4ve:ResetScaleCommand rdfs:comment "Remet la taille des objets à (1,1,1)."@fr , "Resets the objects' scale to (1,1,1)."@en .
sc4ve:ResetTransformCommand rdfs:comment "Remet position, rotation et taille des objets à leur valeur d'origine."@fr , "Resets the objects' position, rotation and scale to their original values."@en .
sc4ve:RotateLeftCommand rdfs:comment "Fait pivoter les objets de 45° vers la gauche (axe Y)."@fr , "Rotates objects 45° to the left (Y axis)."@en .
sc4ve:RotateRightCommand rdfs:comment "Fait pivoter les objets de 45° vers la droite (axe Y)."@fr , "Rotates objects 45° to the right (Y axis)."@en .
sc4ve:SetOpaqueCommand rdfs:comment "Rend les objets entièrement opaques."@fr , "Makes the objects fully opaque."@en .
sc4ve:SetTransparentCommand rdfs:comment "Rend les objets semi-transparents."@fr , "Makes the objects semi-transparent."@en .
sc4ve:SnapToGroundCommand rdfs:comment "Pose les objets sur le sol (raycast vers le bas)."@fr , "Drops the objects onto the ground (downward raycast)."@en .
sc4ve:InvertSelectionCommand rdfs:comment "Inverse la sélection courante."@fr , "Inverts the current selection."@en .
sc4ve:SelectAllCommand rdfs:comment "Sélectionne tous les objets actifs de la scène."@fr , "Selects all active objects in the scene."@en .
sc4ve:ResetSceneCommand rdfs:comment "Remet tous les objets à leur état initial."@fr , "Resets all objects to their initial state."@en .
sc4ve:UndoCommand rdfs:comment "Annule la dernière action."@fr , "Undoes the last action."@en .
sc4ve:RedoCommand rdfs:comment "Rétablit la dernière action annulée."@fr , "Redoes the last undone action."@en .


#################################################################
#    Déictiques de pointage (vocabulaire d'interaction)
#    Mots qui désignent l'objet pointé (« ce/ça » / « this/that »). Lus par
#    CommandVocabulary (filtrés sur la locale) pour produire un filtre Event.
#################################################################

sc4ve:deicticWord rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Mot déictique désignant l'objet pointé."@fr ,
                               "Deictic word referring to the pointed object."@en ;
                  rdfs:label "mot déictique"@fr ,
                             "deictic word"@en .

sc4ve:Deixis rdf:type owl:NamedIndividual ;
             sc4ve:deicticWord "ce"@fr , "ceci"@fr , "ces"@fr , "cet"@fr , "cette"@fr , "ça"@fr ,
                               "this"@en , "that"@en , "these"@en , "those"@en .


#################################################################
#    Messages de confirmation (grounding vocal)
#    Énoncés après une exécution réussie SI le grounding est activé (toggle sur le contrôleur).
#    « {n} » = nombre d'objets affectés ; « (s) » = pluriel résolu selon le nombre (1 → singulier).
#    Pas de valeur pour une commande = pas de confirmation (ex: Count/Describe s'annoncent eux-mêmes).
#################################################################

sc4ve:grounding rdf:type owl:DatatypeProperty ;
                rdfs:domain sc4ve:Command ;
                rdfs:range xsd:string ;
                rdfs:comment "Confirmation vocale après exécution (« {n} » = nombre, « (s) » = pluriel)."@fr ,
                             "Spoken confirmation after execution (« {n} » = count, « (s) » = plural)."@en ;
                rdfs:label "confirmation"@fr ,
                           "grounding"@en .

sc4ve:SelectCommand          sc4ve:grounding "{n} objet(s) sélectionné(s)"@fr , "{n} object(s) selected"@en .
sc4ve:SelectAllCommand       sc4ve:grounding "{n} objet(s) sélectionné(s)"@fr , "{n} object(s) selected"@en .
sc4ve:InvertSelectionCommand sc4ve:grounding "{n} objet(s) sélectionné(s)"@fr , "{n} object(s) selected"@en .
sc4ve:MoveCommand            sc4ve:grounding "{n} objet(s) déplacé(s)"@fr , "{n} object(s) moved"@en .
